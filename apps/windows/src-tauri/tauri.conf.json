{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Tender",
  "version": "0.1.0",
  "identifier": "io.harborline.tender",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "Tender",
        "width": 360,
        "height": 600,
        "minWidth": 360,
        "maxWidth": 360,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://fonts.googleapis.com https://fonts.gstatic.com; connect-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    },
    "trayIcon": {
      "id": "tender-tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "tooltip": "Tender"
    }
  },
  "bundle": {
    "publisher": "Harborline Software",
    "copyright": "Copyright © 2026 Harborline Software",
    "category": "DeveloperTool",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "languages": ["English"],
        "installMode": "currentUser"
      }
    }
  }
}
