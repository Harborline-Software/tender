{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Harborline Toolbox",
  "mainBinaryName": "Harborline Toolbox",
  "version": "0.1.0",
  "identifier": "io.harborline.tender",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Harborline Toolbox",
        "width": 400,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: blob: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/bundles/*.bundle.json": "resources/bundles",
      "resources/catalog/*.app.json": "resources/catalog"
    }
  }
}
