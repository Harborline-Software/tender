{
  "id": "signal-bridge",
  "displayName": "Signal-Bridge",
  "vendor": "Harborline",
  "icon": "signal-bridge",
  "availability": "deprecated",
  "detect": {
    "processPattern": "Sunfish.Bridge.AppHost",
    "healthUrl": "https://localhost:17101/health"
  },
  "install": {
    "sourceKind": "appBundle",
    "source": null,
    "requiresSigning": false
  },
  "services": [
    { "id": "relay", "boot": "process", "healthScope": "local-port" }
  ],
  "actions": [
    { "id": "restart", "kind": "process-restart" }
  ],
  "caveats": [
    {
      "id": "repo-archived",
      "severity": "info",
      "summary": "The signal-bridge repo was archived on GitHub 2026-06-29 and moved out of the active fleet tree (read-only remote). Marked deprecated here rather than removed: honest about detect/status without offering fresh install or management.",
      "appliesWhen": null
    }
  ]
}
